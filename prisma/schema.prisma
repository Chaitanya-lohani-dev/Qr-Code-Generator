generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QRCode {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  url       String
  name      String
  userId    String

  @@index([userId])
}
